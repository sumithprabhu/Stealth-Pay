# ─── Deployer ────────────────────────────────────────────────────────────────
# Private key of the wallet that signs deploy + admin transactions
DEPLOYER_PRIVATE_KEY=

# ─── 0G Network ───────────────────────────────────────────────────────────────
ZERO_G_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_MAINNET_RPC=https://evmrpc.0g.ai

# ─── Explorer ────────────────────────────────────────────────────────────────
ZERO_G_EXPLORER_API_KEY=

# ─── Initial admin roles (defaults to deployer if unset) ─────────────────────
# Address granted DEFAULT_ADMIN_ROLE, PAUSER_ROLE, ENCLAVE_MANAGER_ROLE, UPGRADER_ROLE
INITIAL_ADMIN=

# ─── Protocol fee ────────────────────────────────────────────────────────────
# Basis points; 10 = 0.1%
PROTOCOL_FEE_BPS=10
FEE_RECIPIENT=

# ─── TEE Enclave (for setup.ts) ───────────────────────────────────────────────
# ECDSA public key address generated inside the TEE hardware
ENCLAVE_SIGNING_KEY=
# keccak256 of the TEE code measurement (mrenclave / RTMR digest)
ENCLAVE_MEASUREMENT_HASH=
# Human-readable label for the enclave
ENCLAVE_DESCRIPTION=StealthPay TEE v1

# ─── Token whitelist (for setup.ts) ──────────────────────────────────────────
# Comma-separated ERC-20 addresses to whitelist on PrivacyPool
WHITELIST_TOKENS=

# ─── Misc ─────────────────────────────────────────────────────────────────────
REPORT_GAS=false
