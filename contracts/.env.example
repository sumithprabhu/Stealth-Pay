# Deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# 0G Network RPC endpoints
ZERO_G_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_MAINNET_RPC=https://evmrpc.0g.ai

# Explorer API keys
ZERO_G_EXPLORER_API_KEY=

# Gas reporting
REPORT_GAS=false

# Initial admin address (defaults to deployer if not set)
INITIAL_ADMIN=

# Protocol fee in basis points (e.g. 10 = 0.1%)
PROTOCOL_FEE_BPS=10

# Fee recipient address
FEE_RECIPIENT=
