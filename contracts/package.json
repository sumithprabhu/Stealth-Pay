{
  "name": "@stealthpay/contracts",
  "version": "1.0.0",
  "description": "StealthPay privacy pool smart contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deployAndSetup.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network zeroGTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network zeroGMainnet",
    "setup:local": "hardhat run scripts/setup.ts --network localhost",
    "setup:testnet": "hardhat run scripts/setup.ts --network zeroGTestnet",
    "setup:mainnet": "hardhat run scripts/setup.ts --network zeroGMainnet",
    "upgrade:testnet": "hardhat run scripts/upgrade.ts --network zeroGTestnet",
    "upgrade:mainnet": "hardhat run scripts/upgrade.ts --network zeroGMainnet",
    "verify:testnet": "hardhat run scripts/verify.ts --network zeroGTestnet",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "typecheck": "tsc --noEmit",
    "lint": "solhint 'contracts/**/*.sol'",
    "size": "hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "hardhat": "^2.22.0",
    "hardhat-contract-sizer": "^2.10.0",
    "solhint": "^5.0.0",
    "dotenv": "^16.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0"
  }
}
