# ─── Enclave ──────────────────────────────────────────────────────────────────
# ECDSA private key of the TEE signing keypair.
# On real TDX (0G Compute): generated inside the enclave, never leaves the chip.
# On testnet: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log(w.privateKey)"
ENCLAVE_PRIVATE_KEY=

# ─── Note Encryption ──────────────────────────────────────────────────────────
# 32-byte AES-256-GCM key for encrypting notes stored in 0G Storage.
# On real TDX: sealed to the enclave measurement — regenerate = lose all notes.
# On testnet: node -e "const {ethers}=require('ethers'); console.log(ethers.hexlify(ethers.randomBytes(32)))"
NOTE_ENCRYPTION_KEY=

# ─── Contracts ────────────────────────────────────────────────────────────────
# Copy from contracts/deployments/<network>.json after running deploy.ts
PRIVACY_POOL_ADDRESS=
ATTESTATION_VERIFIER_ADDRESS=

# ─── 0G Chain ─────────────────────────────────────────────────────────────────
ZERO_G_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16600

# ─── 0G Storage ───────────────────────────────────────────────────────────────
# Leave blank to use in-memory storage (dev/test only — data lost on restart)
ZERO_G_STORAGE_NODE=https://rpc-storage-testnet.0g.ai
ZERO_G_INDEXER_NODE=https://indexer-storage-testnet.0g.ai

# ─── API Auth ─────────────────────────────────────────────────────────────────
# Secret the SDK sends in x-api-key header. Must match SDK config.
# Generate: node -e "const {ethers}=require('ethers'); console.log(ethers.hexlify(ethers.randomBytes(32)))"
API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# Comma-separated allowed CORS origins (leave blank to allow all — dev only)
ALLOWED_ORIGINS=

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_NULLIFIERS_PER_ACTION=10
MAX_COMMITMENTS_PER_ACTION=10
# Seconds before a signed attestation expires (default: 1 hour)
ATTESTATION_DEADLINE_SECONDS=3600

# ─── TEE Mode ─────────────────────────────────────────────────────────────────
# "tdx"  — real Intel TDX on 0G Compute (reads /dev/tdx_guest for attestation quote)
# "dev"  — simulated enclave for testnet/local dev (no TDX hardware required)
TEE_MODE=dev
