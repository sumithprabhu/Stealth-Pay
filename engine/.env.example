# ── Enclave identity ──────────────────────────────────────────────────────────
# ECDSA private key generated inside the TEE hardware enclave.
# In production this key is sealed to the enclave and never leaves hardware.
ENCLAVE_PRIVATE_KEY=

# ── 0G Chain ──────────────────────────────────────────────────────────────────
ZERO_G_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16600
PRIVACY_POOL_ADDRESS=
ATTESTATION_VERIFIER_ADDRESS=

# ── 0G Storage ────────────────────────────────────────────────────────────────
ZERO_G_STORAGE_NODE=https://rpc-storage-testnet.0g.ai
ZERO_G_INDEXER_NODE=https://indexer-storage-testnet.0g.ai

# ── Note encryption ───────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM note encryption (derived from enclave key in prod)
NOTE_ENCRYPTION_KEY=

# ── API server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed SDK client origins
ALLOWED_ORIGINS=http://localhost:3001
# Shared API key for SDK → engine authentication
API_KEY=

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_NULLIFIERS_PER_ACTION=10
MAX_COMMITMENTS_PER_ACTION=10
ATTESTATION_DEADLINE_SECONDS=3600
