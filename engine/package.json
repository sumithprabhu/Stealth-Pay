{
  "name": "@stealthpay/engine",
  "version": "1.0.0",
  "description": "StealthPay TEE execution engine — private state management and attestation signing",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "mocha --require ts-node/register --require dotenv/config 'test/**/*.test.ts' --timeout 30000",
    "test:coverage": "nyc npm test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'"
  },
  "dependencies": {
    "@0glabs/0g-ts-sdk": "^0.2.6",
    "ethers": "^6.13.0",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^4.3.0",
    "mocha": "^10.7.0",
    "chai": "^4.4.1",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "nyc": "^17.0.0"
  }
}
